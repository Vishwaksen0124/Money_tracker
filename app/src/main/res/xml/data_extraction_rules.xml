<?xml version="1.0" encoding="utf-8"?>
<!--
    Hardening §20.2: Android 12+ data extraction rules.
    Deny both cloud backup and device-to-device transfer for every domain.
    Combined with allowBackup="false" this blocks ADB backup, Google One backup,
    OEM cloud backup, and Phone-to-Phone restore.
-->
<data-extraction-rules>
    <cloud-backup disableIfNoEncryptionCapabilities="false">
        <exclude domain="root" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
        <exclude domain="file" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
        <exclude domain="file" />
    </device-transfer>
</data-extraction-rules>

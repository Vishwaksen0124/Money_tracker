                <item android:offset="0.75" android:color="#FF22D3A5" />
                <item android:offset="1.0" android:color="#FF2563EB" />
            </gradient>
        </aapt:attr>
    </path>
    <!-- Soft glow blob to give depth. -->
    <path android:pathData="M78,26 m-26,0 a26,26 0 1,0 52,0 a26,26 0 1,0 -52,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="78" android:centerY="26" android:gradientRadius="30">
                <item android:offset="0.0" android:color="#33FFFFFF" />
                <item android:offset="1.0" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>
